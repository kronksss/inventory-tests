{
  "name": "lab6-inventory-ci-cd",
  "version": "1.0.0",
  "description": "CI/CD пайплайн для тестирования инвентаря игрока",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test:unit": "jest --forceExit",
    "test:api": "cucumber-js --require features/step_definitions/**/*.js --format summary",
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "test:ui:report": "npx playwright show-report",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "wait-on": "^7.2.0"
  }
}